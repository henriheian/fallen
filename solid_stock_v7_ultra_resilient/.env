# Configurações do Servidor OAuth
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://app.manus.im

# Banco de Dados (Configure sua conexão local aqui)
DATABASE_URL=mysql://root:password@localhost:3306/solid_stock

# Segurança (Altere para produção)
JWT_SECRET=substitua_por_um_segredo_longo_e_seguro
VITE_APP_ID=solid-stock-erp

# Identidade Visual
VITE_APP_TITLE=Solid Stock - ERP Profissional
VITE_APP_LOGO=https://via.placeholder.com/150

# Configurações de Administrador
OWNER_OPEN_ID=admin_open_id
OWNER_NAME=Administrador

# APIs e Analytics (Opcional)
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua_api_key_aqui
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=sua_frontend_api_key_aqui
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=seu_website_id_aqui

# Modo de Desenvolvimento (Bypass de Login)
# true = login automático como desenvolvedor
# false = fluxo normal de login via portal
AUTO_DEV_LOGIN=true
VITE_AUTO_DEV_LOGIN=true
